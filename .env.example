# ===============================
# DATABASES
# ===============================

# MongoDB (Application data)
SPRING_DATA_MONGODB_URI=mongodb://<MONGO_USER>:<MONGO_PASSWORD>@<MONGO_HOST>:27017/laneflow?authSource=admin

# PostgreSQL (Camunda / workflow engine)
PG_URI=jdbc:postgresql://<PG_HOST>:5432/<PG_DATABASE>?user=<PG_USER>&password=<PG_PASSWORD>

# ===============================
# AUTHENTICATION / SECURITY
# ===============================

# Minimum 256-bit secret
JWT_SECRET=<JWT_SECRET>

# ===============================
# MAIL CONFIGURATION (SMTP)
# ===============================

MAIL_HOST=<SMTP_HOST>
MAIL_PORT=<SMTP_PORT>
MAIL_USERNAME=<SMTP_USERNAME>
MAIL_PASSWORD=<SMTP_PASSWORD>
MAIL_FROM=<MAIL_FROM_ADDRESS>

# ===============================
# APPLICATION
# ===============================

FRONTEND_URL=<FRONTEND_URL>

# ===============================
# CAMUNDA CONFIGURATION
# ===============================

CAMUNDA_ADMIN_USER=<CAMUNDA_ADMIN_USER>
CAMUNDA_ADMIN_PASSWORD=<CAMUNDA_ADMIN_PASSWORD>