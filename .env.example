# ===============================
# DATABASES
# ===============================

# MongoDB (Application data)
SPRING_DATA_MONGODB_URI=mongodb://<MONGO_USER>:<MONGO_PASSWORD>@<MONGO_HOST>:27017/laneflow?authSource=admin

# PostgreSQL (Camunda / workflow engine)
PG_URI=jdbc:postgresql://<PG_HOST>:5432/<PG_DATABASE>?user=<PG_USER>&password=<PG_PASSWORD>

# ===============================
# AUTHENTICATION / SECURITY
# ===============================

# Minimum 256-bit secret
JWT_SECRET=<JWT_SECRET>

# ===============================
# MAIL CONFIGURATION (SMTP)
# ===============================

MAIL_HOST=<SMTP_HOST>
MAIL_PORT=<SMTP_PORT>
MAIL_USERNAME=<SMTP_USERNAME>
MAIL_PASSWORD=<SMTP_PASSWORD>
MAIL_FROM=<MAIL_FROM_ADDRESS>

# ===============================
# APPLICATION
# ===============================

FRONTEND_URL=<FRONTEND_URL>

# CORS
# Exact origins, comma-separated.
APP_CORS_ALLOWED_ORIGINS=<CORS_ALLOWED_ORIGINS>

# Origin patterns only when needed.
APP_CORS_ALLOWED_ORIGIN_PATTERNS=<CORS_ALLOWED_ORIGIN_PATTERNS>
APP_CORS_ALLOWED_METHODS=<CORS_ALLOWED_METHODS>
APP_CORS_ALLOWED_HEADERS=<CORS_ALLOWED_HEADERS>
APP_CORS_ALLOW_CREDENTIALS=<CORS_ALLOW_CREDENTIALS>

# ===============================
# CAMUNDA CONFIGURATION
# ===============================

CAMUNDA_ADMIN_USER=<CAMUNDA_ADMIN_USER>
CAMUNDA_ADMIN_PASSWORD=<CAMUNDA_ADMIN_PASSWORD>

# ===============================
# GOOGLE CLOUD STORAGE
# ===============================

GCP_STORAGE_BUCKET=<GCP_STORAGE_BUCKET>
GCP_STORAGE_EVIDENCE_PREFIX=evidences

# Host path used only by docker-compose for local ADC.
# Inside the container, GOOGLE_APPLICATION_CREDENTIALS is set to /secrets/gcp-credentials.json.
GCP_CREDENTIALS_FILE=D:/path/to/service-account.json
